# Backend API URL (Hono server)
# For local dev use a full URL: http://demo.localhost:3000
# For staging/prod use a template: https://{subdomain}.api-staging.karibu.ai
NEXT_PUBLIC_API_URL=http://localhost:3000

# CDN base URL for public assets (logos, avatar images)
NEXT_PUBLIC_ASSETS_CDN_URL=https://cdn.karibu.ai

# Error Reporting (Sentry)
# Optional: if not set, errors are only logged locally
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
